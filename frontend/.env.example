# ─── InboxOS Frontend — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to git. Only commit this .env.example file.
# Vite requires all public env vars to be prefixed with VITE_

# ─── Backend API URL ──────────────────────────────────────────────────────────
# Points the frontend at the backend API server.
# Local dev: http://localhost:8000
# Production: https://api.yourdomain.com
VITE_API_BASE_URL=http://localhost:8000

# ─── App Config ───────────────────────────────────────────────────────────────
VITE_APP_NAME=InboxOS
VITE_APP_ENV=development
